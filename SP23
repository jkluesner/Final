def geo_filter(df, a, b):
    min_lng, min_lat = a
    max_lng, max_lat = b

    mask = (
        df['start_lng'].between(min_lng, max_lng) &
        df['start_lat'].between(min_lat, max_lat) &
        df['end_lng'].between(min_lng, max_lng) &
        df['end_lat'].between(min_lat, max_lat)
    )

    return df[mask].copy()



def hist_dow(df):
    day_names = ['Monday', 'Tuesday', 'Wednesday', 'Thursday',
                 'Friday', 'Saturday', 'Sunday']
    
    dow_numbers = df['started_at'].dt.day_of_week
    
    dow_names = []
    for x in dow_numbers:
        dow_names.append(day_names[x])
    
    counts = pd.Series(dow_names).value_counts()
    
    result = counts.reset_index()
    result.columns = ['dow', 'count']
    
    return result


def calc_interarrival_times(series):
    sorted_series = series.sort_values()
    diffs = sorted_series.diff()
    minutes = diffs.dt.total_seconds() / 60
    return minutes.dropna().to_numpy()
def build_edges(df):
    # total outgoing trips per start
    outgoing = df.groupby('start')['count'].sum().reset_index()
    outgoing = outgoing.rename(columns={'count': 'outgoing'})

    # merge back
    df = df.merge(outgoing, on='start')

    # compute weights
    df['weight'] = df['count'] / df['outgoing']

    # keep only needed columns
    df = df[['start', 'end', 'weight']]

    # convert to list of tuples
    edges = []
    for row in df.itertuples(index=False):
        edges.append((row.start, row.end, row.weight))

    return sorted(edges)
def merge_cluster_info(locs, clusters, stid_to_name):

    # 1. build station id + cluster table
    cdf = pd.DataFrame({
        'stid': range(len(clusters)),
        'cluster': clusters
    })

    # 2. map id → name
    cdf['name'] = [stid_to_name[i] for i in cdf['stid']]

    # 3. merge with location data
    merged = locs.merge(cdf, on='name')

    # 4. drop extra column
    return merged.drop(columns=['stid'])
